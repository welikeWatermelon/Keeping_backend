# ==========================================
# Docker Compose 환경변수 템플릿
# ==========================================
# 사용법:
# 1. 이 파일을 .env로 복사: cp .env.example .env
# 2. 실제 값으로 변경
# 3. .env 파일은 절대 git에 커밋하지 마세요!
# ==========================================

# Docker Hub 계정
DOCKER_USERNAME=your_dockerhub_username

# ==========================================
# 데이터베이스
# ==========================================
MYSQL_ROOT_PASSWORD=change_this_password
MYSQL_DATABASE=keeping

# ==========================================
# 인증/보안
# ==========================================
# JWT 시크릿 (256bit 이상, 직접 생성 권장)
# 생성 명령: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_here_minimum_256_bits

# ==========================================
# 결제 (Toss)
# ==========================================
# 테스트 키 (실제 결제 안 됨)
TOSS_SECRET_KEY=test_sk_xxxxxxxxxxxxxxxxxxxxxxxx

# ==========================================
# AWS S3 (선택)
# ==========================================
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
AWS_REGION=ap-northeast-2
AWS_S3_BUCKET=

# ==========================================
# SMS (CoolSMS) - 선택
# ==========================================
SMS_API_KEY=
SMS_API_SECRET=
SMS_SEND_NUMBER=

# ==========================================
# Clova OCR (선택)
# ==========================================
CLOVA_OCR_URL=
CLOVA_OCR_SECRET=
CLOVA_TEMPLATE_IDS=39076

# ==========================================
# OpenAI (선택)
# ==========================================
OPENAI_API_KEY=
OPENAI_API_URL=https://api.openai.com/v1/chat/completions
OPENAI_MODEL=gpt-4o

# ==========================================
# 기타
# ==========================================
FE_BASE_URL=http://localhost:3030
