# JWT (모든 서버 동일)
JWT_SECRET=NbPg+8/rCm9yW15pYbbOTXdg1QTPqDcRMA8oauseuOqzrAdkLMcXfmbMLkqt3tZ5HecMd5bnCscx4Iuo2EjnJA==

# 내부 서비스 통신 토큰 (모든 서버 동일)
INTERNAL_AUTH_TOKEN=loadtest-internal-token

# 모놀리스 서버의 AWS Private IP (ACL 호출 대상)
MONOLITH_IP=10.0.1.2

# ========================================
# 캐시 모드 설정 (테스트별 변경)
# ========================================
# NONE : 캐시 미사용, 항상 모놀리스 직접 호출
# PULL : Cache-Aside (캐시 미스 시 조회 후 저장)
# PUSH : Webhook Push + Cache-Aside Fallback (현재 구현)
CACHE_MODE=PUSH

# 캐시 워밍 (PUSH 모드에서만 의미 있음)
CACHE_WARMING_ENABLED=true
