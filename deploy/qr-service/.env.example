# QR Service 서버 환경변수

# MySQL 설정
MYSQL_ROOT_PASSWORD=secure_password_here

# JWT 시크릿 (Monolith와 동일해야 함)
JWT_SECRET=your_jwt_secret_here

# 내부 서비스 통신 토큰 (Monolith와 동일해야 함)
INTERNAL_AUTH_TOKEN=your_internal_token_here

# Monolith EC2 Private IP (ACL 호출용)
MONOLITH_HOST=10.0.1.100

# 로드테스트 백도어 활성화 (테스트용, 운영에서는 false)
LOADTEST_BACKDOOR_ENABLED=false
