{
  "priority": 1,
  "request": {
    "method": "POST",
    "urlPattern": "/v1/payments/.+/cancel"
  },
  "response": {
    "status": 200,
    "fixedDelayMilliseconds": 0,
    "headers": { "Content-Type": "application/json" },
    "transformers": ["response-template"],
    "jsonBody": {
      "paymentKey": "{{request.pathSegments.[2]}}",
      "orderId": "ORDER_CANCEL",
      "status": "CANCELED",
      "totalAmount": 10000,
      "balanceAmount": 0,
      "cancels": [
        {
          "cancelAmount": 10000,
          "cancelReason": "auto-cancel",
          "canceledAt": "2026-01-26T00:00:03+09:00"
        }
      ]
    }
  }
}
